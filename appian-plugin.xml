<appian-plugin key="com.appiancs.plugins.base64" name="Base64 Plugin" version="1.0.0">

  <plugin-info>
    <description>Converts documents to Base64 and decodes Base64 back to file</description>
    <vendor name="AppianCS" url="http://www.appian.com" />
    <version>1.0.0</version>
    <application-version min="24.1" />
  </plugin-info>

  <smart-service name="Image to Base64 Encoder" key="ImageToBase64SmartService"
    class="com.appiancs.plugins.base64.smartservice.ImageToBase64SmartService" />

  <smart-service name="Base64 to File Decoder" key="Base64ToFileSmartService"
    class="com.appiancs.plugins.base64.smartservice.Base64ToFileSmartService" />

</appian-plugin>
